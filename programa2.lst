     3                                  %include "macros.asm" ; incluir biblioteca de macros utilitarias
     1                              <1> ; macros.asm — biblioteca de macros utilitarias
     2                              <1> 
     3                              <1> ; Macro: terminar programa DOS con código de salida 0
     4                              <1> %macro fin_dos 0
     5                              <1>  mov ax, 4C00h
     6                              <1>  int 21h
     7                              <1> %endmacro
     8                              <1> 
     9                              <1> ; Macro: imprimir nueva línea (CR + LF)
    10                              <1> %macro nueva_linea 0
    11                              <1>  mov ah, 02h
    12                              <1>  mov dl, 0Dh
    13                              <1>  int 21h
    14                              <1>  mov dl, 0Ah
    15                              <1>  int 21h
    16                              <1> %endmacro
    17                              <1> 
    18                              <1> ; Macro: imprimir cadena terminada en "$"
    19                              <1> ; %1 = etiqueta de la cadena
    20                              <1> %macro print_str 1
    21                              <1>  mov ah, 09h
    22                              <1>  mov dx, %1
    23                              <1>  int 21h
    24                              <1> %endmacro
    25                              <1> 
    26                              <1> ; Macro: imprimir un carácter único
    27                              <1> ; %1 = valor ASCII del carácter (inmediato o registro)
    28                              <1> %macro print_char 1
    29                              <1>  mov ah, 02h
    30                              <1>  mov dl, %1
    31                              <1>  int 21h
    32                              <1> %endmacro
    33                              <1> 
    34                              <1> ; Macro: leer un carácter desde teclado (sin eco)
    35                              <1> ; Resultado queda en AL
    36                              <1> %macro leer_char 0
    37                              <1>  mov ah, 07h
    38                              <1>  int 21h
    39                              <1> %endmacro
    40                              <1> 
    41                              <1> ; Macro: imprimir una cadena N veces
    42                              <1> ; %1 = etiqueta de la cadena a imprimir
    43                              <1> ; %2 = número de repeticiones (inmediato numérico)
    44                              <1> %macro repetir_str 2
    45                              <1>  mov cx, %2 ; CX = contador de repeticiones
    46                              <1> %%ciclo: ; %% es etiqueta única por expansión
    47                              <1>  mov ah, 09h
    48                              <1>  mov dx, %1
    49                              <1> int 21h
    50                              <1>  loop %%ciclo ; CX--; si CX != 0, repetir
    51                              <1> %endmacro
    52                              <1> 
    53                              <1> ; Macro: imprimir dígito decimal de un valor 0-9 almacenado en AL
    54                              <1> %macro print_digito 0
    55                              <1>  push ax ; preservar AX
    56                              <1>  and al, 0Fh ; asegurar nibble bajo (0-9)
    57                              <1>  add al, 30h ; convertir a ASCII: 0 a"0", 9 a"9"
    58                              <1>  mov ah, 02h
    59                              <1>  mov dl, al
    60                              <1>  int 21h
    61                              <1>  pop ax ; restaurar AX
    62                              <1> %endmacro
