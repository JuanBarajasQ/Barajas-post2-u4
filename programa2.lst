    49                                  
    50                                  ; Procedimientos
    51                                  
    52                                  ; Procedimiento: suma acumulativa 1+2+3+...+N
    53                                  ; Entrada: CX = N (número de iteraciones)
    54                                  ; Salida: AX = suma total
    55                                  sumar_serie:
    56 00000059 51                       push cx ; preservar CX (se modifica con LOOP)
    57 0000005A 31C0                     xor ax, ax ; AX = 0 (acumulador)
    58                                  .paso:
    59 0000005C 01C8                     add ax, cx ; AX += CX (suma N, N-1, ..., 1)
    60 0000005E E2FC                     loop .paso ; CX--; si CX != 0, continuar
    61 00000060 59                       pop cx ; restaurar CX original
    62 00000061 C3                       ret
    63                                  
    64                                  ; NOTA: print_digito solo imprime correctamente para resultados 0-9.
    65                                  ; Para resultados mayores a 9 se requiere conversión completa a decimal.
    66                                  ; En este laboratorio se usa N = 4 para obtener 1+2+3+4 = 10 que es dígito"0".
    67                                  ; Usar N = 3 para obtener 1+2+3 = 6 → imprime correctamente "6".
    68                                  
    69                                  
    70                                  ; Procedimiento: comparar AX y BX e imprimir el mayor
    71                                  ; Modifica: AH, DX (los preserva en la pila)
    72                                  comparar_e_imprimir:
    73 00000062 50                       push ax
    74 00000063 53                       push bx
    75                                  
    76 00000064 39D8                     cmp ax, bx ; actualiza flags: AX - BX (sin modificar operandos)
    77                                  
    78 00000066 7442                     je .son_iguales ; si AX == BX (ZF=1)
    79 00000068 7F21                     jg .ax_mayor ; si AX > BX con signo (SF=OF, ZF=0)
    80                                  
    81                                   ; Caso: BX es mayor
    82                                   print_str msg_mayor ; imprimir etiqueta
    21 0000006A B409                <1>  mov ah, 09h
    22 0000006C BA[6000]            <1>  mov dx, %1
    23 0000006F CD21                <1>  int 21h
    83 00000071 88D8                     mov al, bl ; AL = valor de BX
    84                                   print_digito ; imprimir dígito
